-039c6d981ce5" href="#" class="secondary-button w-inline-block"><div>Join The Camp</div><div class="arrow-tail-button"><div class="arrow-tail-icon w-embed"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-arrow-up-right-icon lucide-arrow-up-right"><path d="M7 7h10v10"></path><path d="M7 17 17 7"></path></svg></div></div></a></div><div class="day-pane-image"><img width="928" height="1233" alt="DJ wearing headphones playing music on a mixer at a tropical outdoor party with people dancing among palm trees." src="/assets/img/dj-outdoor.avif" loading="lazy"></div></div></div><div data-w-tab="Tab 2" class="day-tab-pane w-tab-pane" id="w-tabs-2-data-w-pane-1" role="tabpanel" aria-labelledby="w-tabs-2-data-w-tab-1"><div class="day-pane-content-wrap"><div class="day-timetable"><div class="day-timetable-item"><div class="timetable-time"><div>06:30-07:00</div></div><div>Wake up</div></div><div class="day-timetable-item"><div class="timetable-time"><div>07:00-08:00 </div></div><div>Breakfast</div></div><div class="day-timetable-item"><div class="timetable-time"><div>08:00-08:30 </div></div><div>Transport to surf spot</div></div><div class="day-timetable-item"><div class="timetable-time"><div>08:30-11:30 </div></div><div>Surf session (technique focus)</div></div><div class="day-timetable-item"><div class="timetable-time"><div>11:30-12:00 </div></div><div>Transport to beach club</div></div><div class="day-timetable-item"><div class="timetable-time"><div>12:00-17:00 </div></div><div>Beach club afternoon (lunch, drinks, pool, music, sunbathing)</div></div><div class="day-timetable-item"><div class="timetable-time"><div>17:00-17:30</div></div><div>Transport back to villa</div></div><div class="day-timetable-item"><div class="timetable-time"><div>17:30-19:00 </div></div><div>Rest time at villa</div></div><div class="day-timetable-item"><div class="timetable-time"><div>19:00-19:30</div></div><div>Prepare BBQ together</div></div><div class="day-timetable-item"><div class="timetable-time"><div>19:30-21:00 </div></div><div>BBQ dinner at villa</div></div><div class="day-timetable-item"><div class="timetable-time"><div>21:00-22:30 </div></div><div>Movie night at villa</div></div><div class="day-timetable-item"><div class="timetable-time"><div>22:30-00:00 </div></div><div>Bonfire on the beach</div></div><div class="day-timetable-item"><div class="timetable-time"><div>00:00-08:00</div></div><div>Sleep</div></div></div></div></div></div></div></div></div></div><div class="day-accordion"><div class="day-accordion-header"><div class="day-header-content"><div class="day-heading-wrap"><div class="eyebrow-item">Day 4<br></div><h3>Temple Visit &amp; Culture Day</h3></div><div class="chevron-button"><div class="chevron-icon w-embed"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-chevron-down-icon lucide-chevron-down"><path d="m6 9 6 6 6-6"></path></svg></div></div></div><div class="follow-cursor-wrap" style="display: flex"><div class="follow-cursor"><img width="928" height="1232" alt="A traditional multi-tiered Balinese temple nestled among dense, misty green jungle foliage under a hazy sky." src="/assets/img/jungle-temple-mist.avif" loading="lazy"></div></div><div class="line-fill-wrap"><div class="line-fill-color"></div><div class="line-base u-absolute-full"></div></div></div><div class="day-accordion-body" style="width: 100%; height: 0px"><div class="day-tabs-wrap"><div data-current="Tab 1" data-easing="ease" data-duration-in="300" data-duration-out="100" class="day-tabs-parent w-tabs"><div id="w-node-_3589fdf6-24ea-7cde-8070-541cac23e37d-f2b4ae30" class="day-tabs-menu w-tab-menu" role="tablist"><a data-w-tab="Tab 1" class="day-tabs-link w-inline-block w-